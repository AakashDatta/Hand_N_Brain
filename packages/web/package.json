{
  "name": "@hnb/web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Hand and Brain chess — web client (local play, Stockfish AI, online play).",
  "scripts": {
    "predev": "node scripts/copy-stockfish.mjs",
    "prebuild": "node scripts/copy-stockfish.mjs",
    "pretest": "node scripts/copy-stockfish.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@hnb/core": "*",
    "chess.js": "^1.0.0-beta.8",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.2",
    "react-dom": "^18.3.1",
    "stockfish": "^18.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
