{
  "name": "hand-n-brain",
  "private": true,
  "version": "0.2.0",
  "description": "Hand and Brain chess variant — monorepo (core rules, web app, online server).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names server,web --prefix-colors blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "npm run dev -w @hnb/web",
    "dev:server": "npm run dev -w @hnb/server",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @hnb/server",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
